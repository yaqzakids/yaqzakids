VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_SITE_URL=https://www.yaqzakids.com

# Production also ships public/runtime-config.json (generated by npm run prebuild from .env).
# If Cloudflare build env vars do not work, commit public/runtime-config.json with your anon key.
#   Site URL (optional for local): http://localhost:3000
#   Redirect URLs: http://localhost:3000/reset-password, http://localhost:3000/verify-email, http://localhost:3000/login

# Azure Speech keys are configured as Supabase Edge Function secrets only:
# AZURE_SPEECH_KEY
# AZURE_SPEECH_REGION
# ElevenLabs — prefer Supabase Edge Function secrets in production (do not commit keys)
# VITE_ELEVENLABS_API_KEY=
